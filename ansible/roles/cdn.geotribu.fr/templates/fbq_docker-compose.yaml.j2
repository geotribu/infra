services:
  filebrowser:
    image: gtstef/filebrowser:stable
    volumes:
      - ./data:/home/filebrowser/data
      - /var/www/{{ geotribu_www }}/{{ cdn_subdomain }}/images/:/home/images
      - ./config.yaml:/home/filebrowser/config.yaml:ro
    ports:
      - 127.0.0.1:{{ fbq_internal_port }}:80
    environment:
      - FILEBROWSER_ADMIN_PASSWORD={{ fbq_admin_password}}
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost/health"]
      interval: 60s
      timeout: 3s
      start_period: 10s
      retries: 3
    restart: unless-stopped
